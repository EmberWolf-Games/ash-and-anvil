<form class="sheet-body item-sheet-body">
  <header class="item-header flexrow">
    <img class="profile-img" src="{{document.img}}" data-edit="img" alt="{{document.name}}" />
    <div class="flexcol flex1">
      <input type="text" name="name" value="{{document.name}}" placeholder="{{localize 'Name'}}" />
      <span class="item-type">{{document.type}}</span>
    </div>
  </header>

  {{#if (eq document.type "gear")}}
  <section class="item-fields gear-fields">
    <div class="form-group flexrow">
      <label>{{localize "ASHANVIL.Quantity"}}</label>
      <input type="number" name="system.quantity" value="{{system.quantity}}" min="0" />
      <label>{{localize "ASHANVIL.Weight"}}</label>
      <input type="number" name="system.weight" value="{{system.weight}}" min="0" step="0.1" />
    </div>
    <div class="form-group flexrow">
      <label>{{localize "ASHANVIL.Price"}} ({{localize "ASHANVIL.CurrencyBaseUnit"}})</label>
      <input type="number" name="system.price.value" value="{{system.price.value}}" min="0" />
    </div>
    <div class="form-group flexrow">
      <label><input type="checkbox" name="system.isContainer" {{checked system.isContainer}} /> {{localize "ASHANVIL.IsContainer"}}</label>
      <label>{{localize "ASHANVIL.ContainerKind"}}</label>
      <select name="system.containerKind">
        <option value="" {{#if (eq system.containerKind "")}}selected{{/if}}>—</option>
        <option value="backpack" {{#if (eq system.containerKind "backpack")}}selected{{/if}}>{{localize "ASHANVIL.ContainerBackpack"}}</option>
        <option value="pouch" {{#if (eq system.containerKind "pouch")}}selected{{/if}}>{{localize "ASHANVIL.ContainerPouch"}}</option>
        <option value="quiver" {{#if (eq system.containerKind "quiver")}}selected{{/if}}>{{localize "ASHANVIL.ContainerQuiver"}}</option>
        <option value="sheath" {{#if (eq system.containerKind "sheath")}}selected{{/if}}>{{localize "ASHANVIL.ContainerSheath"}}</option>
        <option value="bag" {{#if (eq system.containerKind "bag")}}selected{{/if}}>{{localize "ASHANVIL.ContainerBag"}}</option>
      </select>
      <label>{{localize "ASHANVIL.ContainerCapacity"}}</label>
      <input type="number" name="system.containerCapacity" value="{{system.containerCapacity}}" min="0" />
    </div>
  </section>
  {{/if}}

  {{#if (eq document.type "spell")}}
  <section class="item-fields spell-fields">
    <div class="form-group flexrow">
      <label>{{localize "ASHANVIL.SpellLevel"}}</label>
      <input type="number" name="system.level" value="{{system.level}}" min="0" />
      <label>{{localize "ASHANVIL.SpellSchool"}}</label>
      <input type="text" name="system.school" value="{{system.school}}" />
    </div>
    <div class="form-group flexrow">
      <label>{{localize "ASHANVIL.SpellTradition"}}</label>
      <select name="system.tradition">
        <option value="arcane" {{#if (eq system.tradition "arcane")}}selected{{/if}}>{{localize "ASHANVIL.SpellTraditionArcane"}}</option>
        <option value="psionic" {{#if (eq system.tradition "psionic")}}selected{{/if}}>{{localize "ASHANVIL.SpellTraditionPsionic"}}</option>
        <option value="divine" {{#if (eq system.tradition "divine")}}selected{{/if}}>{{localize "ASHANVIL.SpellTraditionDivine"}}</option>
      </select>
      <label><input type="checkbox" name="system.prepared" {{checked system.prepared}} /> {{localize "ASHANVIL.SpellPrepared"}}</label>
    </div>
  </section>
  {{/if}}

  {{#if (eq document.type "feature")}}
  <section class="item-fields feature-fields">
    <div class="form-group">
      <label>{{localize "ASHANVIL.FeatureKey"}}</label>
      <input type="text" name="system.key" value="{{system.key}}" />
    </div>
  </section>
  {{/if}}

  <div class="form-group">
    <label>{{localize "ASHANVIL.Description"}}</label>
    {{editor system.description target="system.description" button=true editable=editable engine="prosemirror"}}
  </div>
</form>

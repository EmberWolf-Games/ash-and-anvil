<div class="sheet-zone sheet-zone--details details-tab details-dashboard" data-zone="details">
  {{#unless details.buildComplete}}
  <div class="chargen-banner flexrow">
    <p>{{localize "ASHANVIL.ChargenIncompleteBanner"}}</p>
    <button type="button" data-action="openChargen">{{localize "ASHANVIL.ChargenOpen"}}</button>
  </div>
  {{/unless}}

  <header class="details-top">
    <div class="details-identity-compact flexrow">
      <img class="profile-img profile-img--compact" src="{{details.portrait}}" data-action="editImage" data-field="img" alt="{{details.name}}" />
      <div class="details-name-block flexcol">
        <span class="details-name">{{details.name}}</span>
        <div class="details-meta flexrow">
          <span class="details-meta-item">{{details.ancestry}}{{#if details.ancestryBlended}} · {{details.secondaryAncestry}}{{/if}}</span>
          <span class="details-meta-item">{{details.className}}{{#if details.multiClass}} / {{details.secondaryClassName}}{{/if}}</span>
          <span class="details-meta-item">{{localize "ASHANVIL.TotalLevel"}} {{details.totalLevel}}/{{details.maxTotalLevel}}</span>
          <span class="details-level-chip" title="{{localize 'ASHANVIL.TotalLevel'}}">Lv {{details.totalLevel}}</span>
        </div>
        <div class="details-levels flexrow">
          <label>{{localize "ASHANVIL.PrimaryClassLevel"}}</label>
          <input type="number" name="system.attributes.primaryClassLevel" value="{{details.primaryClassLevel}}" min="0" max="{{details.maxTotalLevel}}" />
          <label>{{localize "ASHANVIL.SecondaryClassLevel"}}</label>
          <input type="number" name="system.attributes.secondaryClassLevel" value="{{details.secondaryClassLevel}}" min="0" max="{{details.maxTotalLevel}}" />
        </div>
      </div>
    </div>

    <div class="details-abilities-row">
      {{#each abilityRows as |row|}}
      <div class="ability-shield" data-ability="{{row.key}}">
        <span class="ability-shield-abbr">{{row.abbr}}</span>
        <span class="ability-shield-mod">{{numberFormat row.ability.mod sign=true}}</span>
        <input class="ability-shield-score" type="number" name="system.abilities.{{row.key}}.value" value="{{row.ability.value}}" min="0" max="50" title="{{row.label}}" />
      </div>
      {{/each}}
    </div>
  </header>

  <div class="details-main-grid">
    <aside class="details-col details-col--combat">
      <section class="details-panel details-panel--ac">
        <div class="ac-shield">
          <span class="ac-shield-label">{{localize "ASHANVIL.ArmorClass"}}</span>
          <span class="ac-shield-value">{{defense.ac.total}}</span>
        </div>
        <div class="combat-mini-grid">
          <div class="combat-mini">
            <span class="mini-label">{{localize "ASHANVIL.TouchAC"}}</span>
            <span class="mini-value">{{defense.touchAc}}</span>
          </div>
          <div class="combat-mini">
            <span class="mini-label">{{localize "ASHANVIL.Quickness"}}</span>
            <span class="mini-value">{{numberFormat combat.quickness sign=true}}</span>
          </div>
          <div class="combat-mini">
            <span class="mini-label">{{localize "ASHANVIL.Edge"}}</span>
            <span class="mini-value">+{{combat.edge}}</span>
          </div>
        </div>
        <div class="ac-breakdown">
          <label>{{localize "ASHANVIL.ArmorCategory"}}</label>
          <select name="system.defense.armorCategory">
            {{#each defense.armorCategories as |cat|}}
            <option value="{{cat}}" {{#if (eq ../defense.armorCategory cat)}}selected{{/if}}>{{cat}}</option>
            {{/each}}
          </select>
          <div class="ac-inputs flexrow">
            <label>{{localize "ASHANVIL.ACBase"}}</label><input type="number" name="system.defense.ac.base" value="{{defense.ac.base}}" />
            <label>{{localize "ASHANVIL.ACArmor"}}</label><input type="number" name="system.defense.ac.armor" value="{{defense.ac.armor}}" />
            <label>{{localize "ASHANVIL.ACShield"}}</label><input type="number" name="system.defense.ac.shield" value="{{defense.ac.shield}}" />
            <label>{{localize "ASHANVIL.Misc"}}</label><input type="number" name="system.defense.ac.misc" value="{{defense.ac.misc}}" />
          </div>
        </div>
      </section>

      <section class="details-panel details-panel--hp">
        <h4 class="panel-title">{{localize "ASHANVIL.Health"}}</h4>
        <div class="hp-adjust-wrap">
          {{> "systems/ash-and-anvil/templates/actor/parts/resource-adjust.hbs"
            display=combat.hpDisplay
            path="attributes.health.value"
            editable=canAdjustResources
          }}
        </div>
        <div class="hp-meta flexrow">
          <label>{{localize "ASHANVIL.HealthMax"}}</label>
          <input type="number" name="system.attributes.health.max" value="{{combat.health.max}}" min="0" {{#unless sheetEditMode}}readonly{{/unless}} />
          <label>{{localize "ASHANVIL.HealthTemp"}}</label>
          <input type="number" class="gameplay-field" name="system.attributes.health.temp" value="{{combat.health.temp}}" min="0" {{#unless canAdjustResources}}readonly{{/unless}} />
        </div>
        <div class="death-favor-grid">
          <div>
            <span class="mini-label">{{localize "ASHANVIL.DeathSaves"}}</span>
            <div class="flexrow">
              <label>{{localize "ASHANVIL.Successes"}}</label>
              <input type="number" class="gameplay-field" name="system.attributes.deathSaves.successes" value="{{combat.deathSaves.successes}}" min="0" max="3" {{#unless canAdjustResources}}readonly{{/unless}} />
              <label>{{localize "ASHANVIL.Failures"}}</label>
              <input type="number" class="gameplay-field" name="system.attributes.deathSaves.failures" value="{{combat.deathSaves.failures}}" min="0" max="3" {{#unless canAdjustResources}}readonly{{/unless}} />
            </div>
          </div>
        </div>
      </section>

      {{#if hasResourceBars}}
      <section class="details-panel details-panel--resources">
        <h4 class="panel-title">{{localize "ASHANVIL.PowerResources"}}</h4>
        {{#each resourceBars as |bar|}}
        {{> "systems/ash-and-anvil/templates/actor/parts/resource-bar.hbs" bar=bar}}
        {{/each}}
      </section>
      {{/if}}

      <section class="details-panel details-panel--speed">
        <h4 class="panel-title">{{localize "ASHANVIL.Speed"}}</h4>
        <div class="speed-compact">
          <div>
            <label>{{localize "ASHANVIL.SpeedWalk"}}</label>
            <span class="speed-effective" title="{{localize 'ASHANVIL.SpeedEffectiveHint'}}">{{speed.walk}}</span>
            <label>{{localize "ASHANVIL.SpeedBase"}}</label>
            <input type="number" name="system.speed.baseWalk" value="{{speed.baseWalk}}" min="0" {{#unless sheetEditMode}}readonly{{/unless}} />
          </div>
          <div><label>{{localize "ASHANVIL.SpeedFly"}}</label><input type="number" name="system.speed.fly" value="{{speed.fly}}" min="0" /></div>
          <div><label>{{localize "ASHANVIL.SpeedSwim"}}</label><input type="number" name="system.speed.swim" value="{{speed.swim}}" min="0" /></div>
          <div><label>{{localize "ASHANVIL.SpeedClimb"}}</label><input type="number" name="system.speed.climb" value="{{speed.climb}}" min="0" /></div>
          <div><label>{{localize "ASHANVIL.SpeedBurrow"}}</label><input type="number" name="system.speed.burrow" value="{{speed.burrow}}" min="0" /></div>
          <div><label>{{localize "ASHANVIL.SpeedHover"}}</label><input type="number" name="system.speed.hover" value="{{speed.hover}}" min="0" /></div>
        </div>
      </section>

      <section class="details-panel details-panel--saves">
        <h4 class="panel-title">{{localize "ASHANVIL.SavingThrows"}}</h4>
        <ul class="save-list">
          {{#each saveRows as |row|}}
          <li class="save-row">
            <input type="checkbox" name="system.saves.{{row.key}}.trained" {{checked row.save.trained}} title="{{localize 'ASHANVIL.Trained'}}" />
            <span class="save-abbr">{{row.abbr}}</span>
            <span class="save-name">{{row.label}}</span>
            <input class="save-misc" type="number" name="system.saves.{{row.key}}.misc" value="{{row.save.misc}}" title="{{localize 'ASHANVIL.Misc'}}" />
            <span class="save-total">{{numberFormat row.save.total sign=true}}</span>
          </li>
          {{/each}}
        </ul>
      </section>
    </aside>

    <section class="details-col details-col--skills">
      <div class="skills-header flexrow">
        <h4 class="panel-title">{{localize "ASHANVIL.Skills"}}</h4>
        <span class="skills-meta">{{skillsMeta.pointsSpent}}/{{skillsMeta.pointsAvailable}} · {{localize "ASHANVIL.MaxRanks"}} {{skillsMeta.maxRanks}}</span>
        <input type="hidden" name="system.skills.pointsAvailable" value="{{skillsMeta.pointsAvailable}}" />
      </div>
      <ul class="skill-list-compact">
        <li class="skill-row skill-row--header">
          <span class="skill-ability">{{localize "ASHANVIL.Ability"}}</span>
          <span class="skill-name">{{localize "ASHANVIL.Skill"}}</span>
          <span class="skill-ranks-h">{{localize "ASHANVIL.Ranks"}}</span>
          <span class="skill-misc-h">{{localize "ASHANVIL.Misc"}}</span>
          <span class="skill-bonus-h">{{localize "ASHANVIL.Bonus"}}</span>
          <span class="skill-passive-h">{{localize "ASHANVIL.Passive"}}</span>
        </li>
        {{#each skillRows as |row|}}
        <li class="skill-row">
          <span class="skill-ability">{{row.abilityAbbr}}</span>
          <span class="skill-name">{{row.label}}</span>
          <input class="skill-ranks" type="number" name="system.skills.entries.{{row.key}}.ranks" value="{{row.entry.ranks}}" min="0" max="{{../skillsMeta.maxRanks}}" title="{{localize 'ASHANVIL.Ranks'}}" />
          <input class="skill-misc" type="number" name="system.skills.entries.{{row.key}}.misc" value="{{row.entry.misc}}" title="{{localize 'ASHANVIL.Misc'}}" />
          <span class="skill-bonus">{{numberFormat row.entry.bonus sign=true}}</span>
          <span class="skill-passive">{{row.passive}}</span>
        </li>
        {{/each}}
        {{#each customSkillRows as |row|}}
        <li class="skill-row skill-row--custom">
          <span class="skill-ability">{{row.abilityAbbr}}</span>
          <span class="skill-name">{{row.label}}</span>
          <input class="skill-ranks" type="number" name="system.skills.custom.{{row.index}}.ranks" value="{{row.entry.ranks}}" min="0" max="{{../skillsMeta.maxRanks}}" />
          <input class="skill-misc" type="number" name="system.skills.custom.{{row.index}}.misc" value="{{row.entry.misc}}" />
          <span class="skill-bonus">{{numberFormat row.entry.bonus sign=true}}</span>
          <span class="skill-passive">{{row.passive}}</span>
        </li>
        {{/each}}
      </ul>
      <button type="button" class="add-skill-btn" data-action="addCustomSkill">{{localize "ASHANVIL.AddCustomSkill"}}</button>
    </section>

    <aside class="details-col details-col--extra">
      <section class="details-panel">
        <h4 class="panel-title">{{localize "ASHANVIL.Lineage"}}</h4>
        <input type="text" name="system.details.lineage" value="{{details.lineage}}" placeholder="{{localize 'ASHANVIL.LineagePlaceholder'}}" />
      </section>

      <details class="details-collapsible" data-collapsible-id="proficiencies" {{#if openCollapsibles.proficiencies}}open{{/if}}>
        <summary>{{localize "ASHANVIL.Proficiencies"}}</summary>
        <div class="details-collapsible-body">
          <div class="prof-armor flexrow">
            <label><input type="checkbox" name="system.proficiencies.armorLight" {{checked proficiencies.armorLight}} /> {{localize "ASHANVIL.ProfArmorLight"}}</label>
            <label><input type="checkbox" name="system.proficiencies.armorMedium" {{checked proficiencies.armorMedium}} /> {{localize "ASHANVIL.ProfArmorMedium"}}</label>
            <label><input type="checkbox" name="system.proficiencies.armorHeavy" {{checked proficiencies.armorHeavy}} /> {{localize "ASHANVIL.ProfArmorHeavy"}}</label>
          </div>
          {{> "systems/ash-and-anvil/templates/actor/parts/tag-field.hbs" fieldKey=tagFields.weapons.fieldKey label=tagFields.weapons.label tags=tagFields.weapons.tags available=tagFields.weapons.available sheetEditMode=sheetEditMode}}
          {{> "systems/ash-and-anvil/templates/actor/parts/tag-field.hbs" fieldKey=tagFields.tools.fieldKey label=tagFields.tools.label tags=tagFields.tools.tags available=tagFields.tools.available sheetEditMode=sheetEditMode}}
          {{> "systems/ash-and-anvil/templates/actor/parts/tag-field.hbs" fieldKey=tagFields.languages.fieldKey label=tagFields.languages.label tags=tagFields.languages.tags available=tagFields.languages.available sheetEditMode=sheetEditMode}}
          {{> "systems/ash-and-anvil/templates/actor/parts/tag-field.hbs" fieldKey=tagFields.gameSets.fieldKey label=tagFields.gameSets.label tags=tagFields.gameSets.tags available=tagFields.gameSets.available sheetEditMode=sheetEditMode}}
        </div>
      </details>

      <details class="details-collapsible" data-collapsible-id="defenses" {{#if openCollapsibles.defenses}}open{{/if}}>
        <summary>{{localize "ASHANVIL.Defenses"}}</summary>
        <div class="details-collapsible-body">
          {{> "systems/ash-and-anvil/templates/actor/parts/tag-field.hbs" fieldKey=tagFields.resistances.fieldKey label=tagFields.resistances.label tags=tagFields.resistances.tags available=tagFields.resistances.available sheetEditMode=sheetEditMode}}
          {{> "systems/ash-and-anvil/templates/actor/parts/tag-field.hbs" fieldKey=tagFields.immunities.fieldKey label=tagFields.immunities.label tags=tagFields.immunities.tags available=tagFields.immunities.available sheetEditMode=sheetEditMode}}
          {{> "systems/ash-and-anvil/templates/actor/parts/tag-field.hbs" fieldKey=tagFields.vulnerabilities.fieldKey label=tagFields.vulnerabilities.label tags=tagFields.vulnerabilities.tags available=tagFields.vulnerabilities.available sheetEditMode=sheetEditMode}}
          {{> "systems/ash-and-anvil/templates/actor/parts/tag-field.hbs" fieldKey=tagFields.conditionImmunities.fieldKey label=tagFields.conditionImmunities.label tags=tagFields.conditionImmunities.tags available=tagFields.conditionImmunities.available sheetEditMode=sheetEditMode}}
        </div>
      </details>

      <details class="details-collapsible" data-collapsible-id="heritage" {{#if openCollapsibles.heritage}}open{{/if}}>
        <summary>{{localize "ASHANVIL.Heritage"}}</summary>
        <div class="details-collapsible-body">
          <label><input type="checkbox" {{checked heritage.isVampire}} data-action="toggleHeritage" data-heritage="vampire" /> {{localize "ASHANVIL.HeritageVampire"}}</label>
          <label><input type="checkbox" {{checked heritage.isLycanthrope}} data-action="toggleHeritage" data-heritage="lycanthrope" /> {{localize "ASHANVIL.HeritageLycanthrope"}}</label>
        </div>
      </details>
    </aside>
  </div>
</div>

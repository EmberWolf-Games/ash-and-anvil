<div
  class="equipment-slot equipment-slot--panel {{#if slot.occupied}}occupied{{/if}} {{#if slot.ghost}}equipment-slot--ghost{{/if}} {{#if slot.locked}}equipment-slot--locked{{/if}}"
  data-slot="{{slot.id}}"
  {{#unless slot.locked}}data-drop-zone="equipment"{{/unless}}
  {{#if slot.locked}}data-locked="true" title="{{localize 'ASHANVIL.HandSlotGhostHint'}}"{{/if}}
>
  <span class="slot-panel-label">{{#if slot.ringIndex}}{{slot.abbr}}{{else}}{{slot.label}}{{/if}}</span>
  {{#if slot.item}}
  <button type="button" class="slot-item" data-action="editItem" data-item-id="{{slot.item.id}}" {{#if slot.ghost}}disabled tabindex="-1"{{/if}}>
    <img src="{{slot.item.img}}" alt="" />
    <span class="slot-label">{{slot.item.name}}</span>
  </button>
  <button type="button" class="slot-unequip" data-action="unequipSlot" data-slot="{{slot.id}}" title="{{localize 'ASHANVIL.Unequip'}}">×</button>
  {{else}}
  <span class="slot-empty">{{localize "ASHANVIL.EquipDropHint"}}</span>
  {{/if}}
</div>

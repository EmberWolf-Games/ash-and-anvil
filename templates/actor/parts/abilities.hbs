<h3 class="zone-title">{{localize "ASHANVIL.Abilities"}}</h3>
<div class="abilities-grid grid grid-3col">
  {{#each abilityRows as |row|}}
  <div class="ability flexcol" data-ability="{{row.key}}">
    <label class="ability-label">{{row.label}}</label>
    <input type="number" name="system.abilities.{{row.key}}.value" value="{{row.ability.value}}" {{#unless ../editable}}disabled{{/unless}} />
    <span class="ability-mod">{{numberFormat row.ability.mod sign=true}}</span>
  </div>
  {{/each}}
</div>

<section class="bio-section bio-section--identity">
  <h3 class="zone-title">{{localize "ASHANVIL.BioSectionIdentity"}}</h3>
  <div class="bio-grid grid grid-3col">
    <div class="form-group">
      <label>{{localize "ASHANVIL.BioGender"}}</label>
      <select name="system.details.gender" {{#unless sheetEditMode}}disabled{{/unless}}>
        {{#each bioOptions.genders as |opt|}}
        <option value="{{opt.value}}" {{#if (eq ../bio.gender opt.value)}}selected{{/if}}>{{opt.label}}</option>
        {{/each}}
      </select>
    </div>
    <div class="form-group">
      <label>{{localize "ASHANVIL.BioAlignment"}}</label>
      <select name="system.details.alignment" {{#unless sheetEditMode}}disabled{{/unless}}>
        {{#each bioOptions.alignments as |opt|}}
        <option value="{{opt.value}}" {{#if (eq ../bio.alignment opt.value)}}selected{{/if}}>{{opt.label}}</option>
        {{/each}}
      </select>
    </div>
    <div class="form-group">
      <label>{{localize "ASHANVIL.BioLifestyle"}}</label>
      <select name="system.details.lifestyle" {{#unless sheetEditMode}}disabled{{/unless}}>
        {{#each bioOptions.lifestyles as |opt|}}
        <option value="{{opt.value}}" {{#if (eq ../bio.lifestyle opt.value)}}selected{{/if}}>{{opt.label}}</option>
        {{/each}}
      </select>
    </div>
    <div class="form-group">
      <label>{{localize "ASHANVIL.Subrace"}}</label>
      <input type="text" name="system.details.subrace" value="{{bio.subrace}}" placeholder="{{localize 'ASHANVIL.SubracePlaceholder'}}" {{#unless sheetEditMode}}readonly{{/unless}} />
    </div>
    <div class="form-group">
      <label>{{localize "ASHANVIL.BioFaith"}}</label>
      <input type="text" name="system.details.faith" value="{{bio.faith}}" {{#unless sheetEditMode}}readonly{{/unless}} />
    </div>
  </div>
</section>

